// HairSalonLink - Prisma Schema
// PostgreSQL (Railway managed)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ユーザー (3ロール: superadmin / admin / staff)
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          String    // "superadmin" | "admin" | "staff"
  salonId       String?
  salon         Salon?    @relation("SalonUsers", fields: [salonId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([salonId])
}

// 店舗
model Salon {
  id                  String    @id @default(cuid())
  slug                String    @unique
  name                String
  ownerEmail          String
  address             String?
  phone               String?
  description         String?
  plan                String    @default("standard") // free | standard | pro
  status              String    @default("pending_payment")
  businessHours       Json      @default("{}")
  stripeCustomerId    String?
  stripeSessionId     String?
  lineChannelId       String?
  lineChannelSecret   String?
  lineAccessToken     String?
  lineLiffId          String?
  lineBotUserId       String?   // LINE OA の bot userId (Webhook destination)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  users               User[]        @relation("SalonUsers")
  staff               Staff[]
  customers           Customer[]
  menus               Menu[]
  reservations        Reservation[]
  treatments          TreatmentRecord[]
  coupons             Coupon[]
  messages            Message[]
  designs             HairStyle[]
}

// スタイリスト
// rank: director | top | stylist | junior | assistant
model Staff {
  id              String   @id @default(cuid())
  salonId         String
  salon           Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  name            String
  role            String   @default("stylist")
  rank            String   @default("stylist")
  designationFee  Int      @default(0)
  canBeDesignated Boolean  @default(true)
  email           String?
  bio             String?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  reservations Reservation[]
  treatments   TreatmentRecord[]
  designs      HairStyle[]

  @@index([salonId])
}

model Customer {
  id             String   @id @default(cuid())
  salonId        String
  salon          Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  name           String
  nameKana       String?
  phone          String?
  email          String?
  birthday       String?
  gender         String?
  lineUserId     String?
  source         String   @default("other")
  firstVisitDate String?
  lastVisitDate  String?
  visitCount     Int      @default(0)
  totalSpent     Int      @default(0)
  tags           String[] @default([])
  notes          String?
  isLineFriend   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  reservations Reservation[]
  treatments   TreatmentRecord[]

  @@index([salonId])
  @@index([lineUserId])
  @@unique([salonId, lineUserId], name: "salonId_lineUserId")
}

// メニュー
// category: cut | color | perm | straight | treatment | spa | other
model Menu {
  id                String   @id @default(cuid())
  salonId           String
  salon             Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  name              String
  category          String   @default("cut")
  price             Int
  durationMinutes   Int      @default(60)
  description       String?
  isCombinable      Boolean  @default(true)
  requiresPatchTest Boolean  @default(false)
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())

  reservations Reservation[]

  @@index([salonId])
}

model Reservation {
  id             String   @id @default(cuid())
  salonId        String
  salon          Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  staffId        String?
  staff          Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)
  menuId         String?
  menu           Menu?    @relation(fields: [menuId], references: [id], onDelete: SetNull)
  menuName       String?
  menuPrice      Int?
  menuIds        String[] @default([])
  designated     Boolean  @default(false)
  designationFee Int      @default(0)
  date           String
  startTime      String
  endTime        String
  status         String   @default("confirmed")
  source         String   @default("web")
  notes          String?
  reminderSent   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  treatments TreatmentRecord[]

  @@index([salonId, date])
  @@index([customerId])
}

// カルテ: 薬剤履歴は美容室の生命線
model TreatmentRecord {
  id                String   @id @default(cuid())
  salonId           String
  salon             Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customerId        String
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staffId           String?
  staff             Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)
  reservationId     String?
  reservation       Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  date              String
  menuName          String
  totalPrice        Int      @default(0)
  durationMinutes   Int      @default(60)
  photos            String[] @default([])
  beforePhotos      String[] @default([])
  afterPhotos       String[] @default([])
  hairType          String?
  damageLevel       Int?
  lastColorDate     String?
  lastPermDate      String?
  chemicalUsed      Json?
  allergies         String?
  notes             String?
  satisfactionScore Int?
  createdAt         DateTime @default(now())

  @@index([customerId])
}

model Coupon {
  id             String   @id @default(cuid())
  salonId        String
  salon          Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  discountType   String   @default("percent")
  discountValue  Int
  minPurchase    Int      @default(0)
  validFrom      String?
  validUntil     String?
  maxUses        Int?
  usedCount      Int      @default(0)
  targetSegment  String   @default("all")
  code           String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model Message {
  id            String    @id @default(cuid())
  salonId       String
  salon         Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  type          String    @default("broadcast")
  title         String
  content       String
  targetSegment String    @default("all")
  sentCount     Int       @default(0)
  openedCount   Int       @default(0)
  clickedCount  Int       @default(0)
  status        String    @default("draft")
  scheduledAt   DateTime?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
}

// ヘアスタイルギャラリー
model HairStyle {
  id           String   @id @default(cuid())
  salonId      String
  salon        Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  staffId      String?
  staff        Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)
  title        String
  category     String?
  length       String?  // short | bob | medium | long
  color        String?
  genderTarget String?  // mens | ladies | unisex
  photoUrl     String?
  tags         String[] @default([])
  likesCount   Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
}
